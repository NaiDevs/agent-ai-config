# ============================================================
# MCP Secrets — copia este archivo a mcp.env y llena los valores
# mcp.env está en .gitignore y NUNCA se sube al repo
# ============================================================

# ── PostgreSQL — una variable por proyecto ────────────────────────────────
# Formato: postgresql://usuario:password@host:puerto/nombre_db

YALO_LABODEGA_DEV=postgresql://postgres:password@host:5432/dbname

# ── Otros tokens ──────────────────────────────────────────────────────────

# GitHub → github.com/settings/tokens → Classic → permisos: repo, read:org, read:user
GITHUB_PERSONAL_ACCESS_TOKEN=ghp_your_token_here

# Resend → resend.com/api-keys
RESEND_API_KEY=re_your_key_here
