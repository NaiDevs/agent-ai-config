# ============================================================
# MCP Secrets — copia este archivo a mcp.env y llena los valores
# mcp.env está en .gitignore y NUNCA se sube al repo
# ============================================================
#
# Convención de nombres (para auto-detección en setup.ps1):
#   NOMBRE_DEV    → PostgreSQL    → MCP: pg-nombre
#   NOMBRE_SS     → SQL Server    → MCP: ss-nombre
#   NOMBRE_REDIS  → Redis         → MCP: redis-nombre
#
# Convención VPN:
#   Agrega "# vpn" en la línea ANTES de la variable para marcarla como
#   VPN-required. El setup la agrega automáticamente a disabledMcpjsonServers
#   en Claude Code. Habilitala manualmente cuando tengas VPN activa.
#
#   Ejemplo:
#     # vpn
#     YALO_AUTH_DEV=postgresql://...
#
# ============================================================

# ── PostgreSQL ────────────────────────────────────────────────────────────────
# Formato: postgresql://usuario:password@host:5432/nombre_db
# Genera MCP: pg-yalo, pg-bodega, etc.

# vpn
YALO_DEV=postgresql://usuario:password@host:5432/nombre_db

# vpn
BODEGA_DEV=postgresql://usuario:password@host:5432/nombre_db

# ── SQL Server ────────────────────────────────────────────────────────────────
# Formato: Server=host,1433;Database=nombre;User Id=usuario;Password=pass;TrustServerCertificate=True
# Genera MCP: ss-yalo, ss-corinsa, etc.

# vpn
# YALO_SS=Server=host,1433;Database=nombre;User Id=usuario;Password=pass;TrustServerCertificate=True

# vpn
# CORINSA_SS=Server=host,1433;Database=nombre;User Id=usuario;Password=pass;TrustServerCertificate=True

# ── Redis ─────────────────────────────────────────────────────────────────────
# Formato: redis://host:6379 o redis://:password@host:6379
# Genera MCP: redis-yalo, redis-bodega, etc.
# YALO_REDIS=redis://localhost:6379
# BODEGA_REDIS=redis://:password@host:6379

# ── GitHub ────────────────────────────────────────────────────────────────────
# github.com/settings/tokens → Classic → permisos: repo, read:org, read:user
GITHUB_PERSONAL_ACCESS_TOKEN=

# ── Resend (email) ─────────────────────────────────────────────────────────
# resend.com/api-keys
# RESEND_API_KEY=

# ── Docker ───────────────────────────────────────────────────────────────────
# Solo si Docker Desktop usa un socket no estándar.
# Dejar vacío para usar el default del sistema (/var/run/docker.sock o npipe).
# DOCKER_HOST=

# ── Firebase Admin ───────────────────────────────────────────────────────────
# console.firebase.google.com → Configuración del proyecto → Cuentas de servicio
# Generar nueva clave privada → descarga el JSON → extraer los 3 campos
# FIREBASE_PROJECT_ID=
# FIREBASE_CLIENT_EMAIL=
# FIREBASE_PRIVATE_KEY=

# ── AWS ──────────────────────────────────────────────────────────────────────
# IAM → Usuarios → Claves de acceso (mínimo permisos necesarios, nunca admin)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-east-1

# ── Azure ─────────────────────────────────────────────────────────────────────
# Azure Portal → App registrations → tu app → Certificates & secrets
# AZURE_TENANT_ID=
# AZURE_CLIENT_ID=
# AZURE_CLIENT_SECRET=
# AZURE_SUBSCRIPTION_ID=
