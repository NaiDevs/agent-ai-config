# ============================================================
# MCP Secrets — copia este archivo a mcp.env y llena los valores
# mcp.env está en .gitignore y NUNCA se sube al repo
# ============================================================

# ── GitHub MCP ───────────────────────────────────────────────
# Crear en: github.com → Settings → Developer settings
#           → Personal access tokens → Tokens (classic)
# Permisos: repo, read:org, read:user
GITHUB_PERSONAL_ACCESS_TOKEN=ghp_your_token_here

# ── PostgreSQL MCP ────────────────────────────────────────────
# Formato: postgresql://usuario:password@host:puerto/nombre_db
# Ejemplos:
#   Local:   postgresql://postgres:password@localhost:5432/dev_db
#   Remoto:  postgresql://naidelyn:pass@db.server.com:5432/labodega_dev
DATABASE_URL=postgresql://postgres:password@localhost:5432/dev_db

# ── SQL Server MCP ────────────────────────────────────────────
# Para proyectos CORINSA, EMSULA Doctor (legacy .NET 4.6.1)
# Formato ADO.NET:
#   Local:   Server=localhost,1433;Database=dev_db;User Id=sa;Password=pass;TrustServerCertificate=True
#   Remoto:  Server=mi-servidor.database.windows.net;Database=db;User Id=user;Password=pass;Encrypt=True
SQLSERVER_CONNECTION=Server=localhost,1433;Database=dev_db;User Id=sa;Password=your_password;TrustServerCertificate=True

# ── Brave Search MCP ──────────────────────────────────────────
# Crear en: brave.com/search/api
# Plan gratuito: 2,000 queries/mes
BRAVE_API_KEY=BSA_your_key_here
