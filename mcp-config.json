{
  "mcpServers": {
    "github":       { "command": "npx", "args": ["-y", "@modelcontextprotocol/server-github"], "shell": "powershell" },
    "filesystem":   { "command": "npx", "args": ["-y", "@modelcontextprotocol/server-filesystem", "C:/Users/{USERNAME}/OneDrive/Documentos/Proyectos", "C:/Users/{USERNAME}/.claude"], "shell": "powershell" },
    "memory":       { "command": "npx", "args": ["-y", "@modelcontextprotocol/server-memory"], "shell": "powershell" },

    "YALO_LABODEGA_DEV": { "command": "powershell", "args": ["-Command", "npx -y mcp-server-postgres $env:YALO_LABODEGA_DEV"] }
  }
}
